{
  "family": "inkra-web",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "1024",
  "memory": "2048",
  "executionRoleArn": "arn:aws:iam::318928518060:role/InkraECSTaskExecutionRole",
  "taskRoleArn": "arn:aws:iam::318928518060:role/InkraECSTaskRole",
  "containerDefinitions": [
    {
      "name": "web",
      "image": "IMAGE_PLACEHOLDER",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 3000,
          "protocol": "tcp"
        }
      ],
      "healthCheck": {
        "command": ["CMD-SHELL", "node -e \"require('http').get('http://localhost:3000/api/health', (r) => { process.exit(r.statusCode === 200 ? 0 : 1) })\" || exit 1"],
        "interval": 30,
        "timeout": 10,
        "retries": 3,
        "startPeriod": 60
      },
      "environment": [
        {"name": "NODE_ENV", "value": "production"},
        {"name": "PORT", "value": "3000"},
        {"name": "HOSTNAME", "value": "0.0.0.0"},
        {"name": "AWS_REGION", "value": "us-east-2"},
        {"name": "AWS_S3_BUCKET", "value": "inkra-uploads-prod"},
        {"name": "AWS_S3_BUCKET_AUDIT_LOGS", "value": "inkra-audit-logs-prod"},
        {"name": "AWS_S3_BUCKET_BACKUPS", "value": "inkra-backups-prod"},
        {"name": "AWS_S3_BUCKET_EXPORTS", "value": "inkra-exports-prod"},
        {"name": "AWS_S3_BUCKET_RECORDINGS", "value": "inkra-recordings-prod"},
        {"name": "EMAIL_ENABLED", "value": "true"},
        {"name": "MARKETING_URL", "value": "https://oninkra.com"},
        {"name": "NEXT_PUBLIC_APP_URL", "value": "https://app.oninkra.com"}
      ],
      "secrets": [
        {"name": "DATABASE_URL", "valueFrom": "arn:aws:secretsmanager:us-east-2:318928518060:secret:inkra/runtime-secrets-SIkCQf:DATABASE_URL::"},
        {"name": "DIRECT_URL", "valueFrom": "arn:aws:secretsmanager:us-east-2:318928518060:secret:inkra/runtime-secrets-SIkCQf:DIRECT_URL::"},
        {"name": "REDIS_URL", "valueFrom": "arn:aws:secretsmanager:us-east-2:318928518060:secret:inkra/runtime-secrets-SIkCQf:REDIS_URL::"},
        {"name": "SUPABASE_SERVICE_ROLE_KEY", "valueFrom": "arn:aws:secretsmanager:us-east-2:318928518060:secret:inkra/runtime-secrets-SIkCQf:SUPABASE_SERVICE_ROLE_KEY::"},
        {"name": "ANTHROPIC_API_KEY", "valueFrom": "arn:aws:secretsmanager:us-east-2:318928518060:secret:inkra/runtime-secrets-SIkCQf:ANTHROPIC_API_KEY::"},
        {"name": "DEEPGRAM_API_KEY", "valueFrom": "arn:aws:secretsmanager:us-east-2:318928518060:secret:inkra/runtime-secrets-SIkCQf:DEEPGRAM_API_KEY::"},
        {"name": "STRIPE_SECRET_KEY", "valueFrom": "arn:aws:secretsmanager:us-east-2:318928518060:secret:inkra/runtime-secrets-SIkCQf:STRIPE_SECRET_KEY::"},
        {"name": "STRIPE_WEBHOOK_SECRET", "valueFrom": "arn:aws:secretsmanager:us-east-2:318928518060:secret:inkra/runtime-secrets-SIkCQf:STRIPE_WEBHOOK_SECRET::"},
        {"name": "TWILIO_ACCOUNT_SID", "valueFrom": "arn:aws:secretsmanager:us-east-2:318928518060:secret:inkra/runtime-secrets-SIkCQf:TWILIO_ACCOUNT_SID::"},
        {"name": "TWILIO_AUTH_TOKEN", "valueFrom": "arn:aws:secretsmanager:us-east-2:318928518060:secret:inkra/runtime-secrets-SIkCQf:TWILIO_AUTH_TOKEN::"},
        {"name": "TWILIO_API_KEY", "valueFrom": "arn:aws:secretsmanager:us-east-2:318928518060:secret:inkra/runtime-secrets-SIkCQf:TWILIO_API_KEY::"},
        {"name": "TWILIO_API_SECRET", "valueFrom": "arn:aws:secretsmanager:us-east-2:318928518060:secret:inkra/runtime-secrets-SIkCQf:TWILIO_API_SECRET::"},
        {"name": "MFA_ENCRYPTION_KEY", "valueFrom": "arn:aws:secretsmanager:us-east-2:318928518060:secret:inkra/runtime-secrets-SIkCQf:MFA_ENCRYPTION_KEY::"},
        {"name": "TRUSTED_DEVICE_SECRET", "valueFrom": "arn:aws:secretsmanager:us-east-2:318928518060:secret:inkra/runtime-secrets-SIkCQf:TRUSTED_DEVICE_SECRET::"},
        {"name": "CRON_SECRET", "valueFrom": "arn:aws:secretsmanager:us-east-2:318928518060:secret:inkra/runtime-secrets-SIkCQf:CRON_SECRET::"}
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/inkra-web",
          "awslogs-region": "us-east-2",
          "awslogs-stream-prefix": "ecs",
          "awslogs-create-group": "true"
        }
      }
    }
  ]
}
