{
  "name": "inkra-monorepo",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "turbo run dev",
    "dev:web": "turbo run dev --filter=@inkra/web",
    "dev:marketing": "turbo run dev --filter=@inkra/marketing",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "db:generate": "turbo run db:generate --filter=@inkra/web",
    "db:push": "turbo run db:push --filter=@inkra/web",
    "db:migrate": "turbo run db:migrate --filter=@inkra/web",
    "db:studio": "pnpm --filter @inkra/web db:studio",
    "test": "turbo run test",
    "test:e2e": "turbo run test:e2e --filter=@inkra/web",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "turbo": "^2.4.0"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=20"
  }
}
