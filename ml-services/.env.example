# ML Services Environment Variables

# Application
DEBUG=true
LOG_LEVEL=DEBUG
VERSION=0.1.0

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5433/ml_services

# Redis
REDIS_URL=redis://localhost:6380/0

# Authentication
SERVICE_API_KEY=your-secure-api-key-here

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000

# AWS
AWS_REGION=us-east-1
AWS_S3_BUCKET_MODELS=inkra-ml-models
AWS_S3_BUCKET_AUDIT=inkra-ml-audit
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_DEFAULT=1000
